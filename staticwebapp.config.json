{
    "navigationFallback": {
        "rewrite": "/index.html",
        "exclude": [
            "*.{css,js,svg,png,jpg,jpeg,gif,ico,woff,woff2,ttf,eot,json,map}"
        ]
    },
    "globalHeaders": {
        "X-Content-Type-Options": "nosniff",
        "Cache-Control": "no-cache"
    },
    "routes": [
        {
            "route": "/assets/*",
            "headers": {
                "Cache-Control": "public, max-age=31536000, immutable"
            }
        }
    ]
}